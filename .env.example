# ============================================================================
#  @drarzter/kafka-client — environment configuration reference
# ============================================================================
#
#  This file documents EVERY environment variable understood by the library's
#  config helpers (`kafkaClientConfigFromEnv` / `consumerOptionsFromEnv`).
#  Copy it to `.env`, delete the lines you don't need, and fill in values.
#
#  ---------------------------------------------------------------------------
#  HOW LOADING WORKS
#  ---------------------------------------------------------------------------
#  The library NEVER reads a .env file itself. Load one before constructing the
#  client using one of:
#
#    * Node 20.6+ built-in:   node --env-file=.env dist/main.js
#    * dotenv package:        import 'dotenv/config'  (top of your entrypoint)
#
#  Then wire the parsed values into the constructor:
#
#    const { clientId, groupId, brokers, options } = kafkaClientConfigFromEnv();
#    const kafka = new KafkaClient(
#      clientId ?? 'my-svc',
#      groupId  ?? 'my-grp',
#      brokers  ?? ['localhost:9092'],
#      { ...options, onMessageLost: alerting },  // code-level values still win
#    );
#
#  ---------------------------------------------------------------------------
#  PRECEDENCE — READ THIS
#  ---------------------------------------------------------------------------
#      explicit code options  >  env vars  >  built-in library defaults
#
#  Env vars only FEED the constructor/consumer arguments. Anything you write in
#  code overrides the corresponding env value; anything absent from the env
#  leaves the library default untouched. Unset variables produce no key at all.
#
#  ---------------------------------------------------------------------------
#  VALUE FORMATS
#  ---------------------------------------------------------------------------
#    boolean : true | false | 1 | 0 | yes | no   (case-insensitive)
#    number  : any value accepted by Number() (NaN throws, naming the var)
#    list    : comma-separated; entries trimmed, empties dropped
#
#  Malformed booleans / numbers / enums throw at parse time with the offending
#  variable name in the message — fail fast, not at first send.
# ============================================================================


# ============================================================================
#  CONNECTION  (prefix KAFKA_)
# ============================================================================
#  Identity and broker endpoints. These three feed the positional KafkaClient
#  constructor arguments (clientId, groupId, brokers) rather than the options
#  object. `KAFKA_CLIENT_ID` should be stable and unique per service; the
#  transactional producer id defaults to `${clientId}-tx`.
# ----------------------------------------------------------------------------

# string  — first constructor arg. Identifies this client to the broker.
KAFKA_CLIENT_ID=my-service

# string  — second constructor arg. Default consumer group for all consumers.
KAFKA_GROUP_ID=my-service-group

# list    — third constructor arg. host:port entries, comma-separated.
KAFKA_BROKERS=localhost:9092


# ============================================================================
#  SECURITY  (prefix KAFKA_ ; maps to KafkaClientOptions.security)
# ============================================================================
#  TLS + SASL authentication. Secure-by-default rules apply once ANY of these
#  is set:
#    * SASL configured with SSL unset  → TLS is enabled automatically.
#    * No security against a REMOTE broker → a one-time warning (silence with
#      KAFKA_ALLOW_INSECURE=true if intentional, e.g. a trusted mesh).
#
#  Cloud IAM (AWS MSK, GCP Managed Kafka) uses the `oauthbearer` mechanism,
#  which requires a token-PROVIDER FUNCTION and therefore CANNOT come from env.
#  Configure oauthbearer in code:
#
#    import { awsMskIamProvider } from '@drarzter/kafka-client/core';
#    security: { sasl: { mechanism: 'oauthbearer',
#                        oauthBearerProvider: awsMskIamProvider({ region: '...' }) } }
# ----------------------------------------------------------------------------

# boolean — enable TLS. Auto-enabled when SASL is set and this is unset.
# KAFKA_SSL=true

# enum    — plain | scram-sha-256 | scram-sha-512  (oauthbearer is code-only).
#           Must be set together with USERNAME and PASSWORD.
# KAFKA_SASL_MECHANISM=scram-sha-512

# string  — SASL username.
# KAFKA_SASL_USERNAME=svc

# string  — SASL password. Prefer a secret manager over a committed .env.
# KAFKA_SASL_PASSWORD=change-me

# boolean — acknowledge an intentionally insecure (plaintext to remote) setup
#           and silence the warning. No effect when SSL/SASL are set.
# KAFKA_ALLOW_INSECURE=false


# ============================================================================
#  PRODUCER / TOPIC MANAGEMENT  (prefix KAFKA_)
# ============================================================================
#  General client behaviour that affects the send path and topic creation.
#  In production prefer to pre-create topics via infrastructure-as-code and
#  leave AUTO_CREATE_TOPICS off.
# ----------------------------------------------------------------------------

# boolean — auto-create topics before first send/subscribe. Default: false.
#           Handy in dev; not recommended in production.
# KAFKA_AUTO_CREATE_TOPICS=false

# boolean — validate string topic keys against any registered schema.
#           Default: true.
# KAFKA_STRICT_SCHEMAS=true

# number  — partitions for auto-created topics. Default: 1.
# KAFKA_NUM_PARTITIONS=1

# string  — transactional producer id used by transaction(). MUST be unique
#           per process/replica across the cluster. Default: `${clientId}-tx`.
# KAFKA_TRANSACTIONAL_ID=my-service-tx-0


# ============================================================================
#  CLOCK RECOVERY  (prefix KAFKA_ ; maps to KafkaClientOptions.clockRecovery)
# ============================================================================
#  On connectProducer() the client can scan the given topics for the highest
#  `x-lamport-clock` header so the monotonic clock survives restarts (used by
#  consumer-side deduplication). Only relevant when you rely on Lamport-clock
#  deduplication AND run a producer.
#
#  `clockRecovery` is only configured when TOPICS is present; the timeout is
#  a no-op without it.
# ----------------------------------------------------------------------------

# list    — topics to scan for the max Lamport clock. Enables clock recovery.
# KAFKA_CLOCK_RECOVERY_TOPICS=orders.created,orders.completed

# number  — max ms to wait before proceeding with a partial result.
#           Default: 30000.
# KAFKA_CLOCK_RECOVERY_TIMEOUT_MS=30000


# ============================================================================
#  LAG THROTTLE  (prefix KAFKA_ ; maps to KafkaClientOptions.lagThrottle)
# ============================================================================
#  Best-effort producer back-pressure: when the monitored consumer group's
#  total lag exceeds MAX_LAG, sends block (up to MAX_WAIT_MS) until lag drops.
#  Requires connectProducer() to start the polling loop.
#
#  The whole block is only configured when MAX_LAG (the sole required field)
#  is set — the other three are ignored on their own.
# ----------------------------------------------------------------------------

# number  — lag threshold (messages) above which sends are delayed.
#           Enables the throttle.
# KAFKA_LAG_THROTTLE_MAX_LAG=10000

# string  — consumer group whose lag is monitored. Default: client's group.
# KAFKA_LAG_THROTTLE_GROUP_ID=my-service-group

# number  — how often to poll getConsumerLag(). Default: 5000.
# KAFKA_LAG_THROTTLE_POLL_INTERVAL_MS=5000

# number  — max ms a send waits while throttled before proceeding anyway.
#           Default: 30000.
# KAFKA_LAG_THROTTLE_MAX_WAIT_MS=30000


# ============================================================================
#  CONSUMER DEFAULTS  (prefix KAFKA_CONSUMER_ ; maps to ConsumerOptions)
# ============================================================================
#  A BASE LAYER of per-consumer defaults, read by consumerOptionsFromEnv().
#  Merge them with code-level options via mergeConsumerOptions(envDefaults,
#  { ... }) — the code layer wins. Note the DIFFERENT prefix (KAFKA_CONSUMER_).
# ----------------------------------------------------------------------------

# string  — override the default consumer group per consumer.
# KAFKA_CONSUMER_GROUP_ID=billing-service

# boolean — start from the earliest offset on first subscribe. Default: false.
# KAFKA_CONSUMER_FROM_BEGINNING=false

# boolean — auto-commit offsets. Default: true. Set false for manual commits.
# KAFKA_CONSUMER_AUTO_COMMIT=true

# number  — log a warning if a handler runs longer than this (does NOT cancel).
# KAFKA_CONSUMER_HANDLER_TIMEOUT_MS=30000

# number  — drop messages older than this (by x-timestamp header), in ms.
# KAFKA_CONSUMER_MESSAGE_TTL_MS=60000

# number  — max messages buffered by consume() before the partition pauses.
#           Only affects consume(). Default: unbounded.
# KAFKA_CONSUMER_QUEUE_HIGH_WATER_MARK=100

# enum    — partition assignment strategy:
#           roundrobin | range | cooperative-sticky (default).
# KAFKA_CONSUMER_PARTITION_ASSIGNER=cooperative-sticky

# string  — static group membership id (group.instance.id). Unique per member.
#           Avoids rebalances on short restarts (k8s rolling deploys).
# KAFKA_CONSUMER_GROUP_INSTANCE_ID=billing-svc-0


# ============================================================================
#  RETRY  (prefix KAFKA_CONSUMER_ ; maps to ConsumerOptions.retry / retryTopics)
# ============================================================================
#  In-process retry with exponential backoff, or the durable retry-topic chain.
#  The `retry` object is only configured when MAX_RETRIES (its sole required
#  field) is set. RETRY_TOPICS requires `retry` to be set.
# ----------------------------------------------------------------------------

# number  — max retry attempts before giving up. Enables the retry policy.
# KAFKA_CONSUMER_RETRY_MAX_RETRIES=3

# number  — base backoff in ms (exponential + jitter). Default: 1000.
# KAFKA_CONSUMER_RETRY_BACKOFF_MS=1000

# number  — backoff cap in ms. Default: 30000.
# KAFKA_CONSUMER_RETRY_MAX_BACKOFF_MS=30000

# boolean — route failures through durable <topic>.retry.<n> topics instead of
#           sleeping in-process. Requires retry. Forces autoCommit=false.
# KAFKA_CONSUMER_RETRY_TOPICS=false

# number  — ms to wait for each retry-level consumer's partition assignment.
#           Default: 10000.
# KAFKA_CONSUMER_RETRY_TOPIC_ASSIGNMENT_TIMEOUT_MS=10000


# ============================================================================
#  DLQ  (prefix KAFKA_CONSUMER_ ; maps to ConsumerOptions.dlq)
# ============================================================================
#  Send messages that exhaust retries to a Dead Letter Queue (<topic>.dlq).
#  Without DLQ, exhausted messages trigger the onMessageLost callback (code).
# ----------------------------------------------------------------------------

# boolean — route exhausted/invalid messages to <topic>.dlq. Default: false.
# KAFKA_CONSUMER_DLQ=true


# ============================================================================
#  DEDUPLICATION  (prefix KAFKA_CONSUMER_ ; maps to ConsumerOptions.deduplication)
# ============================================================================
#  Lamport-clock deduplication (in-memory per topic:partition per group;
#  resets on restart/rebalance). Only configured when STRATEGY is set.
#  A persistent `store` is code-only.
# ----------------------------------------------------------------------------

# enum    — duplicate handling: drop | dlq | topic. Enables deduplication.
#           dlq requires KAFKA_CONSUMER_DLQ=true.
# KAFKA_CONSUMER_DEDUPLICATION_STRATEGY=drop

# string  — destination topic when strategy=topic. Default: <topic>.duplicates.
# KAFKA_CONSUMER_DEDUPLICATION_TOPIC=orders.duplicates


# ============================================================================
#  CIRCUIT BREAKER  (prefix KAFKA_CONSUMER_ ; maps to ConsumerOptions.circuitBreaker)
# ============================================================================
#  Per-partition sliding-window breaker: pauses a partition after too many
#  failures, probes recovery, then resumes. Only configured when THRESHOLD is
#  set; the other three tune the same block.
# ----------------------------------------------------------------------------

# number  — failures within the window that open the circuit. Enables it.
#           Default: 5.
# KAFKA_CONSUMER_CIRCUIT_BREAKER_THRESHOLD=5

# number  — ms to stay OPEN before probing (HALF-OPEN). Default: 30000.
# KAFKA_CONSUMER_CIRCUIT_BREAKER_RECOVERY_MS=30000

# number  — outcomes kept in the sliding window. Default: threshold*2 (min 10).
# KAFKA_CONSUMER_CIRCUIT_BREAKER_WINDOW_SIZE=20

# number  — consecutive HALF-OPEN successes needed to close. Default: 1.
# KAFKA_CONSUMER_CIRCUIT_BREAKER_HALF_OPEN_SUCCESSES=2


# ============================================================================
#  ADVANCED / SUBSCRIBE RETRY  (prefix KAFKA_CONSUMER_ ; ConsumerOptions.subscribeRetry)
# ============================================================================
#  Retry consumer.subscribe() when the topic does not exist yet (e.g. the
#  producing service hasn't created it). Only configured when RETRIES is set.
# ----------------------------------------------------------------------------

# number  — max subscribe attempts. Enables subscribe-retry. Default: 5.
# KAFKA_CONSUMER_SUBSCRIBE_RETRY_RETRIES=5

# number  — delay between subscribe attempts in ms (maps to backoffMs).
#           Default: 5000.
# KAFKA_CONSUMER_SUBSCRIBE_RETRY_DELAY_MS=5000


# ============================================================================
#  WORKED PROFILES  (uncomment ONE block; delete the individual lines above)
# ============================================================================

# ---------------------------------------------------------------------------
#  Profile 1 — LOCAL DEVELOPMENT
#  Plaintext to a local broker, auto-create topics, read from the beginning so
#  you always see historical events. No security warning (broker is local).
# ---------------------------------------------------------------------------
# KAFKA_CLIENT_ID=my-service-dev
# KAFKA_GROUP_ID=my-service-dev
# KAFKA_BROKERS=localhost:9092
# KAFKA_AUTO_CREATE_TOPICS=true
# KAFKA_NUM_PARTITIONS=1
# KAFKA_CONSUMER_FROM_BEGINNING=true

# ---------------------------------------------------------------------------
#  Profile 2 — PRODUCTION on AWS MSK with IAM (sketch)
#  IAM uses the oauthbearer mechanism, which is CODE-ONLY. Set the connection
#  and TLS here; wire the token provider in code:
#
#    import { awsMskIamProvider } from '@drarzter/kafka-client/core';
#    const { clientId, groupId, brokers, options } = kafkaClientConfigFromEnv();
#    new KafkaClient(clientId!, groupId!, brokers!, {
#      ...options,   // includes ssl: true from KAFKA_SSL below
#      security: {
#        ...options.security,
#        sasl: { mechanism: 'oauthbearer',
#                oauthBearerProvider: awsMskIamProvider({ region: 'eu-west-1' }) },
#      },
#    });
# ---------------------------------------------------------------------------
# KAFKA_CLIENT_ID=my-service
# KAFKA_GROUP_ID=my-service
# KAFKA_BROKERS=b-1.msk.eu-west-1.amazonaws.com:9098,b-2.msk.eu-west-1.amazonaws.com:9098
# KAFKA_SSL=true
# KAFKA_CONSUMER_RETRY_MAX_RETRIES=5
# KAFKA_CONSUMER_DLQ=true

# ---------------------------------------------------------------------------
#  Profile 3 — HIGH-THROUGHPUT CONSUMER
#  Manual commits, durable retry topics, DLQ, a circuit breaker to shed load on
#  a failing partition, and static membership to avoid rebalances on redeploy.
# ---------------------------------------------------------------------------
# KAFKA_CLIENT_ID=events-processor
# KAFKA_GROUP_ID=events-processor
# KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
# KAFKA_CONSUMER_AUTO_COMMIT=false
# KAFKA_CONSUMER_RETRY_MAX_RETRIES=5
# KAFKA_CONSUMER_RETRY_BACKOFF_MS=500
# KAFKA_CONSUMER_RETRY_TOPICS=true
# KAFKA_CONSUMER_DLQ=true
# KAFKA_CONSUMER_CIRCUIT_BREAKER_THRESHOLD=10
# KAFKA_CONSUMER_CIRCUIT_BREAKER_RECOVERY_MS=60000
# KAFKA_CONSUMER_PARTITION_ASSIGNER=cooperative-sticky
# KAFKA_CONSUMER_GROUP_INSTANCE_ID=events-processor-0
