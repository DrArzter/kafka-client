{
  "name": "@drarzter/kafka-client",
  "version": "0.11.0",
  "description": "Type-safe Kafka client wrapper for NestJS with typed topic-message maps",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "kafka-client-dlq": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "import": "./dist/otel.mjs",
      "require": "./dist/otel.js"
    },
    "./serde": {
      "types": "./dist/serde.d.ts",
      "import": "./dist/serde.mjs",
      "require": "./dist/serde.js"
    }
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "testing": [
        "./dist/testing.d.ts"
      ],
      "otel": [
        "./dist/otel.d.ts"
      ],
      "serde": [
        "./dist/serde.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kafka",
    "confluent",
    "librdkafka",
    "nestjs",
    "typescript",
    "typed-kafka",
    "kafka-client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DrArzter/kafka-client.git"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.ts --forceExit",
    "test:chaos": "jest --config jest.chaos.config.ts --forceExit",
    "bench": "ts-node bench/throughput.bench.ts",
    "lint": "eslint src --fix",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "containers:clean": "docker ps -aq --filter label=org.testcontainers=true | xargs docker rm -f",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.8.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "@opentelemetry/api": ">=1.0.0",
    "avsc": ">=5.0.0",
    "protobufjs": ">=7.0.0",
    "reflect-metadata": ">=0.1.13",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "avsc": {
      "optional": true
    },
    "protobufjs": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.13",
    "@nestjs/core": "^11.1.13",
    "@opentelemetry/api": "^1.9.0",
    "@testcontainers/kafka": "^12.0.4",
    "@testcontainers/redpanda": "^12.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "avsc": "^5.7.7",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "pg": "^8.13.1",
    "prettier": "^3.8.1",
    "protobufjs": "^7.4.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
